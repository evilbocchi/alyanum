{
    "name": "@antivivi/alyanum",
    "version": "1.1.11",
    "description": "Alisa Mikhailovna \"Alya\" Kujou's go-to big number library for small and large-scale incremental games!",
    "main": "AlyaNum/init.lua",
    "scripts": {
        "prepare": "rokit install --no-trust-check",
        "build": "rbxtsc && lune run release.luau",
        "format": "prettier --write . && rk StyLua src test",
        "test": "lune run test",
        "watch": "rbxtsc -w",
        "docs": "typedoc",
        "prepublishOnly": "npm run build && npm run docs",
        "postpublish": "rk wally publish"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/evilbocchi/alyanum.git"
    },
    "keywords": [],
    "author": "evilbocchi",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/evilbocchi/alyanum/issues"
    },
    "homepage": "https://github.com/evilbocchi/alyanum#readme",
    "types": "AlyaNum/index.d.ts",
    "files": [
        "AlyaNum",
        "!**/*.tsbuildinfo"
    ],
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@rbxts/compiler-types": "^3.0.0-types.0",
        "@rbxts/types": "^1.0.939",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^10.7.0",
        "eslint-plugin-roblox-ts": "^1.4.0",
        "prettier": "^3.9.5",
        "rkkit": "^0.0.3",
        "roblox-ts": "^3.0.0",
        "typedoc": "^0.28.18",
        "typedoc-material-theme": "^1.4.1",
        "typedoc-plugin-extras": "^4.0.1",
        "typedoc-plugin-missing-exports": "^4.1.4",
        "typedoc-plugin-rename-defaults": "^0.7.3",
        "typescript": "^5.5.3"
    }
}
