{
    "compilerOptions": {
        // required
        "allowSyntheticDefaultImports": true,
        "jsx": "react",
        "jsxFactory": "Roact.createElement",
        "jsxFragmentFactory": "Roact.createFragment",
        "module": "commonjs",
        "noLib": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "moduleDetection": "force",
        "strict": true,
        "target": "ESNext",
        "typeRoots": ["node_modules/@rbxts"],
        "skipLibCheck": true,

        // configurable
        "rootDir": "src",
        "outDir": "AlyaNum",
        "incremental": true,
        "tsBuildInfoFile": "AlyaNum/tsconfig.tsbuildinfo",
        "declaration": true
    },
    "typedocOptions": {
        "entryPoints": ["src/index.d.ts"],
        "out": "docs"
    }
}
